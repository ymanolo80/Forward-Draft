  <Content>
    <Paragraph Type="Scene Heading">
      <Text>INT. WRITING ROOM - NIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A writer stares at a blank page. The cursor waits.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Writer</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not tonight. Tonight we move forward.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading">
      <Text>EXT. CITY STREET - MORNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The first light folds across the buildings.</Text>
    </Paragraph>
  </Content>
